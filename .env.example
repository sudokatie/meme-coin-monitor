# Meme Coin Monitor Environment Variables
# Copy this to .env and fill in your values

# Helius API Keys (comma-separated for rotation)
# With multiple keys, requests are distributed across all keys
# Example: HELIUS_API_KEYS=key1,key2,key3,key4,key5,key6,key7
HELIUS_API_KEYS=your_helius_api_key_here

# Optional: Override default Solana RPC URL (if not using Helius keys above)
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Database connection string
# DATABASE_URL=sqlite+aiosqlite:///data/meme_monitor.db

# Optional: Alert webhook URL
# ALERT_WEBHOOK_URL=https://your-webhook-url.com/alerts

# Optional: Telegram bot for alerts
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: API server settings
# API_HOST=127.0.0.1
# API_PORT=8080
